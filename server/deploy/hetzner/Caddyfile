# Auto-HTTPS reverse proxy for the full Subsumio stack.
# APP_DOMAIN and ENGINE_DOMAIN must have DNS A-records pointing at this box
# BEFORE first boot — Caddy provisions Let's Encrypt certificates on demand.
{$APP_DOMAIN} {
	encode gzip
	reverse_proxy web:3000
}

{$ENGINE_DOMAIN} {
	encode gzip
	reverse_proxy engine:3131
}
