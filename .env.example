# ── Subsumio Web-App (Next.js) — Produktions-Env ──────────────────────────
# Kopiere nach .env.local (Dev) bzw. setze im Hetzner docker-compose .env.

# ── SEO / Domains (PFLICHT für korrektes SEO) ───────────────────────────────
# Kanonische Basis-URL der Plattform. Steuert canonical-Tags, OG-URLs und die
# Sitemap. MUSS auf die echte Domain zeigen — sonst verweisen alle SEO-Signale
# auf eine tote/geparkte Domain.
NEXT_PUBLIC_SITE_URL=https://subsum.eu
# Kanonische öffentliche URL des Subsumio-Produkts. Default "/subsumio" (interne
# Route). Auf "https://subsum.io" setzen, sobald die Domain am Hetzner-Server
# hängt — dann verlinkt der Plattform-Hub nach außen und der Canonical der
# Subsumio-Seiten konsolidiert auf subsum.io.
NEXT_PUBLIC_SUBSUMIO_URL=/subsumio
# Hosts, die auf die Subsumio-Marke routen (Komma-getrennt). Default:
# subsum.io,www.subsum.io,subsumio.com,www.subsumio.com
NEXT_PUBLIC_SUBSUMIO_HOSTS=

# Kanonische öffentliche URL des Taxumio-Produkts. Default "/taxumio" (interne
# Route). Auf "https://taxum.io" setzen, sobald die Domain am Hetzner-Server
# hängt.
NEXT_PUBLIC_TAXUMIO_URL=/taxumio
# Hosts, die auf die Taxumio-Marke routen (Komma-getrennt). Default:
# taxum.io,www.taxum.io,taxumio.com,www.taxumio.com
NEXT_PUBLIC_TAXUMIO_HOSTS=

# Engine-Anbindung (PFLICHT in Produktion — sonst antworten alle Proxies 503).
# URL des subsumio-Servers (gestartet mit: subsumio serve --http --port 3001).
# SUBSUMIO_* ist der primäre Prefix.
SUBSUMIO_API_URL=

# Upload-Limits auf Agenturniveau. Default 1 GB pro Dokument / 200 MB pro Bild.
# Große Uploads werden client-seitig gestaffelt (max 2 große gleichzeitig).
# Der Engine-Prozess MUSS GBRAIN_MAX_UPLOAD_BYTES >= MAX_UPLOAD_BYTES setzen.
# MAX_UPLOAD_BYTES=1073741824
# MAX_IMAGE_BYTES=209715200
# Original-Dateien werden zusätzlich zum extrahierten Text gespeichert (Download/GoBD).
# Default: lokales Volume unter ${GBRAIN_HOME}/files (/data sichern!). Für S3/MinIO
# den storage:-Block in der Engine-Config setzen — siehe docs/DEPLOY_ENGINE.md.

# Shared Secret zwischen Web-App und Engine. MUSS auf BEIDEN Seiten gesetzt
# sein: hier UND als SUBSUMIO_WEB_API_KEY beim Engine-Prozess.
# Ohne Key akzeptiert die Engine jeden Aufrufer!
SUBSUMIO_WEB_API_KEY=

# Internes Service-zu-Service Secret (z.B. Upload → Auto-Analyse).
# Generieren: openssl rand -hex 32
# Ohne diesen Wert wird die Auto-Analyse nach Upload nicht getriggert.
SUBSUMIO_INTERNAL_SECRET=

# Session-Signatur (HMAC). 32+ zufällige Bytes, z. B.: openssl rand -hex 32
AUTH_SECRET=

# Auth-/Usage-Store: Postgres-URL (PFLICHT in Produktion; Dev nutzt .data/).
# Eine der vier Varianten wird erkannt:
SUBSUMIO_AUTH_DATABASE_URL=
# DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# Stripe (Billing) — ohne diese Werte zeigt die UI den "nicht verbunden"-Zustand.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Transaktionale E-Mails (Passwort-Reset, Verifikation, Fristen-Digest) via Resend.
# Ohne Key wird die Mail in die Server-Konsole gedruckt (Dev-Modus).
RESEND_API_KEY=
MAIL_FROM=Subsumio <hello@subsum.io>
MAIL_REPLY_TO=hello@subsum.io
# Eingehende E-Mails via Resend Receiving.
# Webhook-URL: https://deine-domain/api/email/webhook/resend
# Event: email.received
RESEND_WEBHOOK_SECRET=
# Optionaler Fallback-Brain für eingehende Mails ohne Plus-Adresse.
# Plus-Adressen wie hello+brain_abcd@subsum.io werden automatisch geroutet.
EMAIL_INBOUND_DEFAULT_BRAIN_ID=

# Fristen-Digest-Cron (/api/cron/deadlines, täglich 06:00 UTC via supercronic).
# Hetzner: CRON_SECRET wird im cron-Container als Env gesetzt; supercronic
# sendet  curl -H "Authorization: Bearer $CRON_SECRET" …/api/cron/deadlines
CRON_SECRET=

# Öffentliche App-URL (für Links in E-Mails).
NEXT_PUBLIC_APP_URL=

# WhatsApp Business Platform / Cloud API (interner Kanzlei-Assistent).
# Webhook-URL in Meta: https://deine-domain/api/whatsapp/webhook
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: Graph API Version und Medienannahme. Meta-Media-URLs sind nur kurz gültig;
# Kanzlei OS lädt deshalb sofort herunter und speichert Hash + Pfad im Brain.
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_MEDIA_STORAGE_PROVIDER=local
WHATSAPP_MEDIA_STORAGE_DIR=.data/whatsapp-media
WHATSAPP_MEDIA_MAX_BYTES=26214400
# Erlaubte Anwalt-Nummern und Brain-Zuordnung. Nur diese Sender dürfen schreiben.
# Beispiel:
# WHATSAPP_ALLOWED_SENDERS_JSON=[{"phone":"+491701234567","brainId":"brain_abc123","userId":"user_1","name":"RA Mustermann","role":"lawyer"}]
WHATSAPP_ALLOWED_SENDERS_JSON=
# Dev-Fallback, wenn kein JSON gesetzt ist (NUR dev — in Produktion ignoriert, kein env-Fallback):
# WHATSAPP_ALLOWED_PHONE=
# WHATSAPP_DEFAULT_BRAIN_ID=
# WHATSAPP_DEFAULT_USER_NAME=

# Proaktiver KI-Sekretär — Tagesbriefing (Paket 33, P1-SECR-004)
# Genehmigtes Meta-Template für das Briefing außerhalb des 24h-Fensters.
# Ohne dieses Template wird ein außerhalb des Fensters fälliges Briefing geblockt (und auditiert).
# WHATSAPP_BRIEFING_TEMPLATE=daily_briefing
# Quiet Hours (lokale Stunden, Format "START-ENDE", darf Mitternacht überspannen): kein nicht-dringender Versand.
# WHATSAPP_BRIEFING_QUIET_HOURS=21-7

# WhatsApp Voice Message Transcription (OpenAI Whisper API)
# Wenn OPENAI_API_KEY gesetzt ist, werden Sprachnachrichten automatisch transkribiert.
# WHATSAPP_TRANSCRIPTION_MODEL=whisper-1
# WHATSAPP_TRANSCRIPTION_LANGUAGE=de

# WhatsApp Flows (structured forms: case intake, appointment booking)
# RSA private key (PEM format) for decrypting Flow data exchange requests.
# Generate with: openssl genrsa -out flow_private.pem 2048
# Register the public key with Meta when creating a Flow via Flows API.
# WHATSAPP_FLOW_PRIVATE_KEY_PEM=

# ── Encryption & Data (PFLICHT in Produktion) ─────────────────────────────
# AES-256-GCM Key für Verschlüsselung sensibler Felder (API keys, 2FA secrets).
# Generieren: openssl rand -hex 32
SUBSUMIO_ENCRYPTION_KEY=

# File-based Storage (Dev/Self-hosted). Default: .data/ im Projektverzeichnis.
SUBSUMIO_DATA_DIR=

# Demo Brain Slug für öffentliche Demo (niemals ein Tenant-Brain!).
SUBSUMIO_DEMO_BRAIN=demo

# Optional: verteilter Rate-Limiter (Brute-Force-Schutz instanzübergreifend).
# Ohne diese Werte: in-memory pro Instanz (für Single-Instanz ausreichend).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Monitoring & Analytics (optional) ───────────────────────────────────────
# Sentry DSN für Error-Tracking und Performance-Monitoring.
# Erstelle ein Projekt auf https://sentry.io und kopiere den DSN.
NEXT_PUBLIC_SENTRY_DSN=

# PostHog für Product Analytics.
# Erstelle ein Projekt auf https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── SCIM Directory Sync (WorkOS) ────────────────────────────────────────────
# Org-scoped Bearer Tokens für inbound SCIM 2.0 Requests, ein Token pro Mandant.
# Format: "orgId1:token1,orgId2:token2". Jede IdP-Verbindung bekommt ihr
# eigenes Token; Requests werden strikt auf den zugehörigen orgId beschränkt
# (kein Mandant kann Daten eines anderen Mandanten über SCIM sehen/ändern).
# Generieren je Token: openssl rand -hex 32
SCIM_BEARER_TOKENS=
# Legacy/Single-Tenant-Fallback: nur aktiv, wenn SCIM_SINGLE_TENANT_ORG_ID
# ebenfalls gesetzt ist (sonst wird das Token ignoriert — fail-closed).
SCIM_BEARER_TOKEN=
SCIM_SINGLE_TENANT_ORG_ID=
# WorkOS Directory ID (im WorkOS Dashboard unter Directory Sync zu finden).
# Wenn gesetzt, kann die manuelle Synchronisation vom Dashboard ausgelöst werden.
WORKOS_DIRECTORY_ID=
# Optional: Token-Preview für die SCIM-Einstellungsseite (nur Anzeige, nicht sicherheitsrelevant).
# NEXT_PUBLIC_SCIM_TOKEN_PREVIEW=

# ── Engine-Prozess (subsumio serve --http) — separates Env ────────────────
# SUBSUMIO_WEB_API_KEY=           # identisch mit SUBSUMIO_WEB_API_KEY oben
# SUBSUMIO_REQUIRE_TENANT=true    # PFLICHT für Multi-Tenant/SaaS: lehnt jeden
#                                # Request ohne gültigen Tenant-Header mit 400
#                                # ab (fail-closed; 'default' nie erreichbar).
# SUBSUMIO_DATABASE_URL=          # Postgres+pgvector der Engine
# ANTHROPIC_API_KEY=             # für /api/think (KI-Antworten) + Agenten
# OPENAI_API_KEY=                # für Embeddings (hybride Suche)
# GBRAIN_EMBEDDING_IMAGE_OCR=true # OCR für gescannte Dokumente/Bilder (P0-4)
#                                # Standardmäßig AKTIV (Agentur-Qualität).
#                                # Setzen Sie auf false, um OCR zu deaktivieren.
#                                # Benötigt graphicsmagick+ghostscript (im Docker-Image enthalten).
# GBRAIN_OCR_MAX_PAGES=100        # Max. Seiten, die pro gescanntem PDF synchron
#                                # OCR-verarbeitet werden (Timeout-/Kostenschutz).
#                                # 0/negativ = kein Limit.
#
# WICHTIG: Agenten-Jobs (Supervisor/Subagents aus dem Dashboard) braucht
# einen Minion-Worker. Zwei Optionen:
#   subsumio serve --http --with-worker   # Worker im selben Prozess
#                                       # (PFLICHT bei PGLite, ok für kleine
#                                       # Postgres-Deployments)
#   subsumio jobs work                    # dedizierter Worker-Prozess
#                                       # (empfohlen für größere Deployments)
# Ohne Worker bleiben Dashboard-Agenten dauerhaft im Status "queued".

# ── Logging ─────────────────────────────────────────────────────────────────
# Strukturiertes JSON-Logging (debug | info | warn | error). Default: info.
# LOG_LEVEL=info

# ── IP Allow-Listing (G8: Enterprise Security) ──────────────────────────────
# Komma-getrennte IPs/CIDRs, die auf Dashboard/API/Admin zugreifen dürfen.
# Ohne Wert: alle IPs erlaubt (Default). Health-Endpoints sind immer erlaubt.
# SUBSUMIO_IP_ALLOWLIST=10.0.0.0/8,192.168.1.100

# ── App-Hosts (Multi-Domain Routing) ────────────────────────────────────────
# Komma-getrennte Hosts, die auf die Subsumio-App (Dashboard) routen.
# Default: app.subsum.io,cockpit.subsum.io
# SUBSUMIO_APP_HOSTS=app.subsum.io,cockpit.subsum.io

# ── Öffentliche App-URL (für interne Links) ─────────────────────────────────
# SUBSUMIO_APP_URL=https://app.subsum.io

# ── Redis (Presence/Realtime) ───────────────────────────────────────────────
# Optional: für Multi-Instanz Presence (Co-Editing). Ohne Wert: in-memory.
# REDIS_URL=redis://localhost:6379

# ── DocuSign Integration ────────────────────────────────────────────────────
# Für elektronische Unterschriften. Alle Werte aus dem DocuSign Admin.
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_SECRET_KEY=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_BASE_URL=https://account-d.docusign.com
# DOCUSIGN_PRIVATE_KEY=  # RSA private key PEM (für JWT-Auth)
# DOCUSIGN_CONNECT_SECRET=  # Webhook-Signatur-Secret für Connect-Webhooks

# ── DMS Integration (Dokumentenmanagement) ──────────────────────────────────
# Anbindung an externes DMS (z.B. d.velop, ELO, Sharepoint).
# DMS_PROVIDER=  # imanager | netdocuments | sharepoint | box | none
# DMS_BASE_URL=
# DMS_API_KEY=
# SHAREPOINT_SITE_ID=   # optional, auto-discovered if not set
# SHAREPOINT_DRIVE_ID=  # optional, auto-discovered if not set
# BOX_FOLDER_ID=        # optional, defaults to "0" (root)
# BOX_ENTERPRISE_ID=    # optional, for JWT auth

# ── ClamAV (Virus-Scan für Uploads) ─────────────────────────────────────────
# Optional: ClamAV-Server für Viren-Scan hochgeladener Dateien.
# Ohne Wert: kein Viren-Scan (Dev-Modus).
# CLAMAV_HOST=  # z.B. localhost:3310

# ── Perplexity API (KI-Recherche) ───────────────────────────────────────────
# Für Perplexity-basierte Rechtsprechungs-Recherche im Research-Tab.
# PERPLEXITY_API_KEY=

# ── Portal (Mandanten-Portal) ───────────────────────────────────────────────
# Secret für Mandanten-Portal-Token-Signierung.
# Generieren: openssl rand -hex 32
# PORTAL_TOKEN_SECRET=

# ── Sales Notifications ─────────────────────────────────────────────────────
# E-Mail/Slack-Webhook für Sales-Notifications bei neuen Registrierungen.
# SALES_NOTIFY_EMAIL=
# SALES_SLACK_WEBHOOK_URL=

# ── WorkOS (SSO/SAML) ───────────────────────────────────────────────────────
# Für Enterprise SSO. WorkOS API Key und Client ID aus dem WorkOS Dashboard.
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=

# ── Legal Brain ID (Legacy/Single-Tenant) ───────────────────────────────────
# Optional: feste Brain-ID für Legal-Features, wenn nicht pro-User geroutet.
# LEGAL_BRAIN_ID=

# ── Auth Database URL (Alias) ───────────────────────────────────────────────
# Alternative Env-Var für die Auth-DB (gleiche Funktion wie SUBSUMIO_AUTH_DATABASE_URL).
# AUTH_DB_URL=

# ── Internal API Key (Service-zu-Service) ───────────────────────────────────
# Alternative zu SUBSUMIO_INTERNAL_SECRET für interne API-Calls.
# INTERNAL_API_KEY=

# ── GBRAIN Source (Engine-Bezug) ────────────────────────────────────────────
# Optional: Source-ID für den Engine-Bezug (Multi-Source-Setups).
# GBRAIN_SOURCE=

# ── Sentry DSN (Server-side) ────────────────────────────────────────────────
# Server-seitiger Sentry DSN (separat von NEXT_PUBLIC_SENTRY_DSN).
# SENTRY_DSN=

# ── WebSocket URL (Realtime) ────────────────────────────────────────────────
# Öffentliche WS-URL für Realtime-Features (Presence, Live-Updates).
# NEXT_PUBLIC_WS_URL=

# ── Engine Repo URL (Public) ────────────────────────────────────────────────
# Öffentliche URL des Engine-Repos für Doku/Links.
# NEXT_PUBLIC_ENGINE_REPO_URL=

# ── Direct Upload Max Bytes ─────────────────────────────────────────────────
# Client-seitiges Limit für Direct-Uploads (Bytes). Default: 1073741824 (1GB).
# NEXT_PUBLIC_DIRECT_UPLOAD_MAX_BYTES=1073741824

# ── WhatsApp Deadline Template ──────────────────────────────────────────────
# Meta-Template für Fristen-Benachrichtigung außerhalb des 24h-Fensters.
# WHATSAPP_DEADLINE_TEMPLATE=

# ── WhatsApp Signature Check (Dev) ──────────────────────────────────────────
# Nur Dev: Webhook-Signatur-Check deaktivieren. NIEMALS in Produktion setzen!
# WHATSAPP_SKIP_SIGNATURE_CHECK=false

# ── ELSTER (Elektronische Steuererklärung) ───────────────────────────────────
# ELSTER_MODE: disabled (default) | sandbox | production
# In sandbox wird eine Schein-Übermittlung erzeugt; in production muss ein
# ELSTER-Cert konfiguriert oder ein ELSTER_BACKEND_URL-Dienst angebunden sein.
# ELSTER_MODE=disabled
# Base64-kodiertes PKCS#12 Client-Zertifikat für ELSTER (production/sandbox).
# ELSTER_CERT_B64=
# Optionale URL eines externen ELSTER-Vermittler-Dienstes (ERiC-Connector).
# ELSTER_BACKEND_URL=
