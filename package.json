{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e-playwright/smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true next build",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "cap:add": "cap add ios && cap add android",
    "cap:sync": "cap sync",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android",
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then bunx husky; fi",
    "word-addin:build": "cd word-addin && npm install && npm run build",
    "mobile:build": "next build && cap sync"
  },
  "dependencies": {
    "@capacitor/camera": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.0.0",
    "@next/bundle-analyzer": "^15.5.0",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-switch": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sentry/nextjs": "^10.0.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.4",
    "capacitor-native-biometric": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "isomorphic-dompurify": "^3.18.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "posthog-js": "^1.390.2",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.56.0",
    "recharts": "^2.15.0",
    "svix": "^1.95.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "uuid": ">=11.1.1",
    "elliptic": "^6.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@chromatic-com/storybook": "^3.0.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.1.0"
  }
}
