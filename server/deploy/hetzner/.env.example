# ──────────────────────────────────────────────────────────────────────────
# Subsumio engine — Hetzner production env. Copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:  openssl rand -hex 32
# NEVER commit .env (it holds live secrets).
# ──────────────────────────────────────────────────────────────────────────

# Public app + API hostnames (DNS A-records → this box). Caddy issues HTTPS.
APP_DOMAIN=subsum.io
ENGINE_DOMAIN=api.subsum.io

# Postgres credentials. User/DB default to "subsumio" — override if your
# existing volume was initialized with different names.
POSTGRES_USER=subsumio
POSTGRES_DB=subsumio
POSTGRES_PASSWORD=

# Shared secret between web and engine.  openssl rand -hex 32
SUBSUMIO_WEB_API_KEY=

# Web session + encryption secrets.  openssl rand -hex 32
AUTH_SECRET=
SUBSUMIO_INTERNAL_SECRET=
SUBSUMIO_ENCRYPTION_KEY=

# Cron secret — protects all /api/cron/* endpoints. supercronic sends this as Bearer token.
CRON_SECRET=

# Multi-tenant hardening — MANDATORY for SaaS (rejects any request without a tenant).
SUBSUMIO_REQUIRE_TENANT=true

# Behind Caddy → trust the proxy headers.
SUBSUMIO_HTTP_TRUST_PROXY=true

# CORS allow-list — the domains the browser calls from (comma-separated).
# Used by the engine for direct-to-engine browser uploads.
GBRAIN_HTTP_CORS_ORIGIN=https://subsum.io,https://www.subsum.io,https://subsumio.com

# Public engine URL for browser direct uploads. The browser sends large files
# directly here. Must match ENGINE_DOMAIN + HTTPS.
NEXT_PUBLIC_ENGINE_URL=https://api.subsum.io

# Web app URL — used by the engine to fire post-upload callbacks (reconcile
# case documents, contradiction probe). Must be the internal Docker hostname
# on Hetzner (e.g. http://web:3000) so the callback doesn't leave the box.
SUBSUMIO_WEB_URL=http://web:3000

# Large legal-document uploads. The full Hetzner stack has no function body
# caps, so the browser and server can both advertise/accept 500 MB documents.
MAX_UPLOAD_BYTES=524288000
MAX_TABULAR_UPLOAD_BYTES=20971520
MAX_IMAGE_BYTES=209715200
NEXT_PUBLIC_DIRECT_UPLOAD_MAX_BYTES=524288000
# Multipart envelope includes headers/boundaries above the 500 MB file limit.
GBRAIN_MAX_UPLOAD_BYTES=536870912

# Optional ADVOKAT Local Bridge. Mount a read-only ADVOKAT export/document
# mirror from the Windows server (often via SMB/CIFS) into the engine.
ADVOKAT_IMPORT_HOST_PATH=./imports/advokat

# ── AI providers ──────────────────────────────────────────────────────────
# Claude = answers / Subsumio copilot / agents (the reasoning).
ANTHROPIC_API_KEY=
# Embeddings = the vector search (Anthropic has no embeddings API — use one of these).
OPENAI_API_KEY=
# VOYAGE_API_KEY=
# Optional embedding tuning (defaults are sensible):
# SUBSUMIO_EMBEDDING_MODEL=text-embedding-3-small
# SUBSUMIO_EMBEDDING_DIMENSIONS=1536
# Document OCR — REQUIRED for a law firm. Scanned/photographed documents arrive
# as images; without this they have no searchable/chattable text. OCR output is
# auto-tagged `extraction_unverified`. Needs the OpenAI key above (vision model).
SUBSUMIO_EMBEDDING_IMAGE_OCR=true
# Shared statute corpus every tenant reads alongside their own files.
# Import via: import-statutes-split.ts --source law-at / law-de / law-ch / law-eu
# Read-only federation — never widens write scope. Public text → no isolation risk.
SUBSUMIO_SHARED_READ_SOURCES=law-at,law-de,law-ch,law-eu

# ── Optional: S3-compatible object storage for original file bytes (GoBD) ──────
# Supports Cloudflare R2, Hetzner Object Storage, MinIO, or AWS S3.
# Without this, files land on the engine-data volume (fine for pilots).
#
# Hetzner Object Storage example:
#   R2_ENDPOINT=https://fsn1.your-objectstorage.com   # or nbg1 / hel1
#   R2_BUCKET=subsumio-vault
#   R2_ACCESS_KEY_ID=<access key>
#   R2_SECRET_ACCESS_KEY=<secret key>
#   R2_REGION=us-east-1                               # Hetzner ignores region but SDK requires it
#
# Cloudflare R2 example:
#   R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   R2_BUCKET=subsumio-vault
#   R2_ACCESS_KEY_ID=<access key>
#   R2_SECRET_ACCESS_KEY=<secret key>
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=us-east-1

# Disabled until S3-backed persistent upload sessions and streaming confirm are
# enabled and load-tested. The normal direct-to-engine upload remains active.
SUBSUMIO_PRESIGNED_UPLOAD_ENABLED=false

# Tenant/brain receiving documents from the installation-level ADVOKAT mirror.
# Required for SaaS; obtain it from the firm's user/org record.
ADVOKAT_TARGET_SOURCE_ID=

# ──────────────────────────────────────────────────────────────────────────
# Offsite backup (restic) — encrypted DB + original-file backups off the VM.
# Leave BACKUP_RESTIC_REPOSITORY blank to disable (the backup service idles).
# Restore + verification: see deploy/hetzner/backup/ and docs/BACKUP-RESTORE-PLAN.md.
#
# IMPORTANT: store BACKUP_RESTIC_PASSWORD OFFLINE too (password manager + paper).
# Without it the encrypted backups are unrecoverable — losing the VM AND the
# password means total data loss.
#
# Pick ONE Hetzner target (use a DIFFERENT location than the production VM):
#
#  A) Hetzner Object Storage (S3-compatible) — RECOMMENDED (enable versioning /
#     object-lock on the bucket for ransomware resistance):
#       BACKUP_RESTIC_REPOSITORY=s3:https://nbg1.your-objectstorage.com/<bucket>/restic
#       BACKUP_S3_ACCESS_KEY_ID=<key>
#       BACKUP_S3_SECRET_ACCESS_KEY=<secret>
#
#  B) Hetzner Storage Box (SFTP) — cheapest. Needs an SSH key mounted into the
#     backup container + a known_hosts entry (see README). Then:
#       BACKUP_RESTIC_REPOSITORY=sftp:u123456@u123456.your-storagebox.de:/restic
#     (AWS_* not used in this mode.)
#
# Generate the password with:  openssl rand -base64 48
BACKUP_RESTIC_REPOSITORY=
BACKUP_RESTIC_PASSWORD=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# ──────────────────────────────────────────────────────────────────────────
# At-rest encryption of original files (envelope: per-file AES-256-GCM DEK,
# wrapped by this KEK). Leave blank to keep files as plaintext (current default).
# Enabling is SAFE + non-destructive: existing files stay readable, only newly
# written files get encrypted. restic backups are already encrypted independently.
#
# IMPORTANT: store this key OFFLINE too — losing the volume AND this key means the
# encrypted originals are unrecoverable. (The restic backup password is separate.)
#
# Generate with:  openssl rand -base64 32   (must decode to exactly 32 bytes)
SUBSUMIO_STORAGE_ENCRYPTION_KEY=
SUBSUMIO_STORAGE_ENCRYPTION_KEY_ID=k1
# Key rotation: set a NEW active key + id above, move the OLD one here so older
# files still decrypt. JSON {"<old-id>":"<old-base64-key>"}.
SUBSUMIO_STORAGE_ENCRYPTION_RETIRED_KEYS=
