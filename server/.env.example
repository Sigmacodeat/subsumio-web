# ─── Subsumio Engine — production environment ──────────────────────────────
# Copy to your platform's secret store (Railway/Fly), NOT into the image.

# REQUIRED ────────────────────────────────────────────────────────────────────
# Long random secret gating the web API. MUST equal the frontend's
# SUBSUMIO_WEB_API_KEY. Generate: openssl rand -hex 32
SUBSUMIO_WEB_API_KEY=

# Fail-closed multi-tenant: reject any request without a valid tenant header.
# MANDATORY for the hosted SaaS (so "default" scope is unreachable over HTTP).
SUBSUMIO_REQUIRE_TENANT=true

# DATABASE — pick ONE ──────────────────────────────────────────────────────────
# Postgres + pgvector (recommended for multi-tenant SaaS; Railway/Supabase/Neon).
# Leave empty to use the embedded PGLite store on the /data volume (single-writer,
# fine for a single firm / pilot).
DATABASE_URL=

# EMBEDDINGS (needed for vector search / RAG) — set ONE ────────────────────────
OPENAI_API_KEY=
# VOYAGE_API_KEY=

# DOCUMENT OCR — REQUIRED for a law firm ────────────────────────────────────────
# Scanned/photographed documents arrive as images (JPG/PNG/HEIC/TIFF). Without
# this, an uploaded image has NO searchable/chattable text — only a filename and
# a visual embedding. ON for the legal SaaS so a photo of a Schriftsatz is fully
# usable. OCR text is auto-tagged `extraction_unverified` (check against original).
# Needs a vision-capable expansion model (OpenAI key above covers it).
SUBSUMIO_EMBEDDING_IMAGE_OCR=true

# SHARED STATUTE CORPUS — every tenant reads these alongside their own source ──
# The law corpus (imported via import-statutes-split.ts --source law-at/law-de)
# lives in shared, public, read-only sources. List them here so a firm's chat
# and search retrieve and cite the actual statutes, not just their own files.
# Read-only federation — never widens write scope. Public text → no isolation risk.
SUBSUMIO_SHARED_READ_SOURCES=law-at,law-de,law-ch,law-eu

# OPTIONAL ─────────────────────────────────────────────────────────────────────
# One-time token to create the first admin over HTTP.  openssl rand -hex 32
SUBSUMIO_ADMIN_BOOTSTRAP_TOKEN=
# Behind a PaaS proxy (Railway/Fly terminate TLS):
SUBSUMIO_HTTP_TRUST_PROXY=true
# Restrict CORS to your frontend origin:
SUBSUMIO_HTTP_CORS_ORIGIN=https://subsum.io
# Where the embedded PGLite store + config live (the container sets this):
# SUBSUMIO_HOME=/data
# PORT is injected by the platform; the entrypoint passes it to `serve --port`.
